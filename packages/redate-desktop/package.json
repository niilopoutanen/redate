{
  "name": "redate",
  "version": "0.1.0",
  "author": "Niilo Poutanen",
  "description": "App for renaming files by exif data",
  "private": true,
  "main": "build/electron.js",
  "type": "module",
  "scripts": {
    "electron": "concurrently \"vite dev\" \"wait-on tcp:5173 && tsc && node cleaner.cjs && electron .\" --kill-others",
    "svelte": "vite dev",
    "package": "vite build && tsc && node cleaner.cjs && electron-builder"
  },
  "build": {
    "appId": "dev.poutanen.redate",
    "productName": "ReDate",
    "files": [
      "build/**/*",
      "package.json"
    ],
    "asar": true,
    "mac": {
      "target": "dmg",
      "icon": "static/icon.icon"
    },
    "win": {
      "target": "nsis",
      "icon": "static/favicon.ico"
    },
    "extraFiles": []
  },
  "devDependencies": {
    "@electron/packager": "^18.3.4",
    "@rollup/rollup-darwin-arm64": "^4.60.1",
    "@sveltejs/adapter-static": "^3.0.4",
    "@sveltejs/kit": "^2.53.4",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "concurrently": "^8.2.2",
    "electron": "32.0.1",
    "electron-builder": "^26.8.1",
    "kill-port": "^2.0.1",
    "sass-embedded": "^1.77.8",
    "svelte": "^5.53.6",
    "svelte-check": "^4.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.0",
    "vite": "^7.3.1",
    "wait-on": "^8.0.0"
  },
  "dependencies": {
    "conf": "^15.1.0",
    "dmg-license": "^1.0.11",
    "electron-store": "^11.0.2",
    "ogl": "^1.0.11",
    "redate-cli": "*"
  }
}
